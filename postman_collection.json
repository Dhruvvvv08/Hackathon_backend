{
  "info": {
    "name": "Sports Slot Booking API",
    "description": "Complete API collection for the Sports Slot Booking System.\n\nSetup:\n1. Set the `baseUrl` variable to your server URL (default: http://localhost:5000/api)\n2. Set the `userId` variable to one of: user_1, user_2, user_3, user_4, user_5\n3. Run the seed script before testing: npm run seed",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "user_1",
      "type": "string"
    },
    {
      "key": "venueId",
      "value": "",
      "type": "string"
    },
    {
      "key": "bookingId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Venues",
      "item": [
        {
          "name": "Get All Venues",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data.length > 0) {",
                  "    pm.collectionVariables.set('venueId', res.data[0]._id);",
                  "    console.log('Set venueId to: ' + res.data[0]._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/venues",
              "host": ["{{baseUrl}}"],
              "path": ["venues"]
            }
          }
        },
        {
          "name": "Get Venue Slots",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/venues/{{venueId}}/slots?date=2025-01-15",
              "host": ["{{baseUrl}}"],
              "path": ["venues", "{{venueId}}", "slots"],
              "query": [
                {
                  "key": "date",
                  "value": "2025-01-15"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data._id) {",
                  "    pm.collectionVariables.set('bookingId', res.data._id);",
                  "    console.log('Set bookingId to: ' + res.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "{{userId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"venueId\": \"{{venueId}}\",\n  \"date\": \"2025-01-15\",\n  \"startTime\": \"10:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            }
          }
        },
        {
          "name": "Create Booking (Duplicate — Expect 409)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "{{userId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"venueId\": \"{{venueId}}\",\n  \"date\": \"2025-01-15\",\n  \"startTime\": \"10:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            }
          }
        },
        {
          "name": "Create Booking (Invalid Input — Expect 400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "{{userId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"venueId\": \"{{venueId}}\",\n  \"date\": \"invalid-date\",\n  \"startTime\": \"25:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            }
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{userId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/bookings/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "{{bookingId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get User Bookings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{userId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "bookings"]
            }
          }
        }
      ]
    }
  ]
}
